#ifndef ICM45686_H
#define ICM45686_H

#include <stdint.h>
#include <stddef.h>
#include "../hal/spi.h"
#include "../math/math.h"

#define ICM45686_WHO_AM_I 0x72
#define ICM45686_PWR_MGMT0 0x10
#define ICM45686_ACCEL_DATA_X1_UI 0x00
#define ICM45686_GYRO_DATA_X1_UI 0x06
#define ICM45686_ACCEL_CONFIG0 0x1B
#define ICM45686_GYRO_CONFIG0 0x1C

typedef struct {
    spi_t *spi;
} icm45686_t;

void icm45686_init(icm45686_t *device, spi_t *spi);
uint8_t icm45686_read_id(icm45686_t *device);
void icm45686_read_accel(icm45686_t *device, float *data);
void icm45686_read_gyro(icm45686_t *device, float *data);

#endif // ICM45686_H
